# MongoDB
MONGODB_URI=mongodb+srv://...

# JWT
JWT_SECRET=your-secret

# Email (nodemailer)
# ...

# URL frontend — dùng cho redirect sau thanh toán VNPAY
FRONTEND_URL=http://localhost:3000

# VNPAY (sandbox: https://sandbox.vnpayment.vn/)
# Mặc định: thanh toán VNPAY mở cổng giả lập (/payment/vnpay-sandbox).
# Chỉ redirect sang cổng VNPAY thật khi đặt VNPAY_USE_REAL=true VÀ điền đủ TMN + secret.
VNPAY_USE_REAL=false
# Lấy TMN code + Hash secret trong tài khoản sandbox VNPAY
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# URL backend công khai để VNPAY gọi lại (phải trùng cấu hình trên cổng VNPAY)
VNPAY_RETURN_URL=http://localhost:5000/api/orders/vnpay-return
# Hoặc dùng BACKEND_PUBLIC_URL + đường dẫn cố định (nếu không set VNPAY_RETURN_URL)
BACKEND_PUBLIC_URL=http://localhost:5000

PORT=5000
